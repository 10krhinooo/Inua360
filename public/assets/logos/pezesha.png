d;font-size:24px">Become an <br/>Embedded partner</p><p class="my-3" style="font-family:Poppins">Let your merchants access affordable inventory credit on demand</p></div><div class="col-md-4 col-xl-4 text-center"><a class="btn btn-primary text-uppercase pezesha-btn" type="submit" style="font-family:Poppins,sans-serif;background:rgb(115,191,67);border-style:none;margin-left:0;margin-top:56px;font-size:24px" href="/supply-chain/">learn more</a></div></div></div></section><section id="embedd-mobile"><div class="container" style="padding-left:10px;padding-right:10px"><div class="row" style="border-radius:26px;padding-left:0px;margin-left:0px;margin-right:0px;border-style:solid;border-color:rgb(115,191,67);padding-top:16px;padding-bottom:16px;text-align:center"><div class="col-md-4 col-lg-2 col-xl-2 text-end d-lg-flex justify-content-lg-center" style="border-radius:14px;padding-right:2px;margin-left:0px;padding-top:24px"><img style="display:block;margin:0 auto" class="img-fluid d-lg-flex" src="data:image/svg+xml;base64,"/></div><div class="col-md-4 col-lg-5 col-xl-5" style="padding-left:6px"><p class="my-3" style="font-family:Poppins;font-weight:bold;font-size:24px">Become an <br/>Embedded partner</p><p class="my-3" style="font-family:Poppins">Let your merchants access affordable inventory credit on demand</p></div><div class="col-md-4 col-xl-4 text-center"><a class="btn btn-primary text-uppercase pezesha-btn" type="submit" style="font-family:Poppins, sans-serif;background:rgb(115,191,67);border-style:none;margin-left:0px;font-size:24px;margin-top:24px" href="/supply-chain/">learn more</a></div></div></div></section><section class="testimonials" style="font-family:Poppins;margin-top:53px"><div class="container"><h2 class="fw-bold title-pezesha" style="font-family:Source Serif Pro,serif;color:#60A137;text-align:center">Testimonials</h2></div><div class="carousel slide" data-bs-ride="carousel" data-bs-interval="10000" id="carousel-t"><div class="carousel-inner"><div class="carousel-item active"><div class="col-9 text-center mx-auto testimonial-content"><div data-gatsby-image-wrapper="" class="gatsby-image-wrapper gatsby-image-wrapper-constrained rounded-circle"><div style="max-width:100;display:block"><img alt="" role="presentation" aria-hidden="true" src="data:image/svg+xml;charset=utf-8,%3Csvg%20height=&#x27;100&#x27;%20width=&#x27;100&#x27;%20xmlns=&#x27;http://www.w3.org/2000/svg&#x27;%20version=&#x27;1.1&#x27;%3E%3C/svg%3E" style="max-width:100%;display:block;position:static"/></div><img aria-hidden="true" data-placeholder-image="" style="opacity:1;transition:opacity 500ms linear;background-color:transparent;position:absolute;top:0;left:0;bottom:0;right:0" decoding="async" src="data:image/png;base64," alt=""/><picture><source type="image/webp" data-srcset="/static/39991390e223bfb84a80394d61e56a48/59d64/njogu.webp 100w,/static/39991390e223bfb84a80394d61e56a48/d16d0/njogu.webp 200w" sizes="(min-width: 100px) 100px, 100vw"/><img data-gatsby-image-ssr="" data-main-image="" style="opacity:0" sizes="(min-width: 100px) 100px, 100vw" decoding="async" loading="lazy" data-src="/static/39991390e223bfb84a80394d61e56a48/3d34d/njogu.png" data-srcset="/static/39991390e223bfb84a80394d61e56a48/3d34d/njogu.png 100w,/static/39991390e223bfb84a80394d61e56a48/443a8/njogu.png 200w" alt="SME"/></picture><noscript><picture><source type="image/webp" srcSet="/static/39991390e223bfb84a80394d61e56a48/59d64/njogu.webp 100w,/static/39991390e223bfb84a80394d61e56a48/d16d0/njogu.webp 200w" sizes="(min-width: 100px) 100px, 100vw"/><img data-gatsby-image-ssr="" data-main-image="" style="opacity:0" sizes="(min-width: 100px) 100px, 100vw" decoding="async" loading="lazy" src="/static/39991390e223bfb84a80394d61e56a48/3d34d/njogu.png" srcSet="/static/39991390e223bfb84a80394d61e56a48/3d34d/njogu.png 100w,/static/39991390e223bfb84a80394d61e56a48/443a8/njogu.png 200w" alt="SME"/></picture></noscript><script type="module">const t="undefined"!=typeof HTMLImageElement&&"loading"in HTMLImageElement.prototype;if(t){const t=document.querySelectorAll("img[data-main-image]");for(let e of t){e.dataset.src&&(e.setAttribute("src",e.dataset.src),e.removeAttribute("data-src")),e.dataset.srcset&&(e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset"));const t=e.parentNode.querySelectorAll("source[data-srcset]");for(let e of t)e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset");e.complete&&(e.style.opacity=1,e.parentNode.parentNode.querySelector("[data-placeholder-image]").style.opacity=0)}}</script></div><p class="text-center" style="font-family:Poppins,sans-serif;margin-top:18px"><span style="background-color:rgba(239, 239, 239, 0.92)">“I could not access a loan from the banks due to my inability to provide collateral. My Pezesha loans enabled me to expand my business and meet all my running costs. I now own 3 stalls. I have also trained and employed over 10 youths to help them make a living in the metal works and welding sector.”</span><br/></p><p class="signature" style="font-family:Poppins,sans-serif;font-size:16px">Njogu<br/> Metal work (Juakali), Kenya</p></div></div><div class="carousel-item"><div class="col-9 text-center mx-auto testimonial-content"><div data-gatsby-image-wrapper="" class="gatsby-image-wrapper gatsby-image-wrapper-constrained rounded-circle"><div style="max-width:100;display:block"><img alt="" role="presentation" aria-hidden="true" src="data:image/svg+xml;charset=utf-8,%3Csvg%20height=&#x27;100&#x27;%20width=&#x27;100&#x27;%20xmlns=&#x27;http://www.w3.org/2000/svg&#x27;%20version=&#x27;1.1&#x27;%3E%3C/svg%3E" style="max-width:100%;display:block;position:static"/></div><img aria-hidden="true" data-placeholder-image="" style="opacity:1;transition:opacity 500ms linear;background-color:transparent;position:absolute;top:0;left:0;bottom:0;right:0" decoding="async" src="data:image/png;base64," alt=""/><picture><source type="image/webp" data-srcset="/static/679b328b31fd539b06511b56deb64d99/59d64/nakirema.webp 100w,/static/679b328b31fd539b06511b56deb64d99/36c59/nakirema.webp 220w" sizes="(min-width: 100px) 100px, 100vw"/><img data-gatsby-image-ssr="" data-main-image="" style="opacity:0" sizes="(min-width: 100px) 100px, 100vw" decoding="async" loading="lazy" data-src="/static/679b328b31fd539b06511b56deb64d99/3d34d/nakirema.png" data-srcset="/static/679b328b31fd539b06511b56deb64d99/3d34d/nakirema.png 100w,/static/679b328b31fd539b06511b56deb64d99/24674/nakirema.png 220w" alt="SME"/></picture><noscript><picture><source type="image/webp" srcSet="/static/679b328b31fd539b06511b56deb64d99/59d64/nakirema.webp 100w,/static/679b328b31fd539b06511b56deb64d99/36c59/nakirema.webp 220w" sizes="(min-width: 100px) 100px, 100vw"/><img data-gatsby-image-ssr="" data-main-image="" style="opacity:0" sizes="(min-width: 100px) 100px, 100vw" decoding="async" loading="lazy" src="/static/679b328b31fd539b06511b56deb64d99/3d34d/nakirema.png" srcSet="/static/679b328b31fd539b06511b56deb64d99/3d34d/nakirema.png 100w,/static/679b328b31fd539b06511b56deb64d99/24674/nakirema.png 220w" alt="SME"/></picture></noscript><script type="module">const t="undefined"!=typeof HTMLImageElement&&"loading"in HTMLImageElement.prototype;if(t){const t=document.querySelectorAll("img[data-main-image]");for(let e of t){e.dataset.src&&(e.setAttribute("src",e.dataset.src),e.removeAttribute("data-src")),e.dataset.srcset&&(e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset"));const t=e.parentNode.querySelectorAll("source[data-srcset]");for(let e of t)e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset");e.complete&&(e.style.opacity=1,e.parentNode.parentNode.querySelector("[data-placeholder-image]").style.opacity=0)}}</script></div><p class="text-center" style="font-family:Poppins,sans-serif;margin-top:18px">“I applied for a Pezesha loan when I was almost closing shop as I could not restock my business. Since taking my first loan with Pezesha, my business has grown two folds. I no longer worry about running out of stock because Pezesha loans are disbursed in a timely manner.”<br/></p><p class="signature" style="font-family:Poppins,sans-serif;font-size:16px">Nakirema <br/> FMCG , Uganda</p></div></div><div class="carousel-item"><div class="col-9 text-center mx-auto testimonial-content"><div data-gatsby-image-wrapper="" class="gatsby-image-wrapper gatsby-image-wrapper-constrained rounded-circle"><div style="max-width:100;display:block"><img alt="" role="presentation" aria-hidden="true" src="data:image/svg+xml;charset=utf-8,%3Csvg%20height=&#x27;100&#x27;%20width=&#x27;100&#x27;%20xmlns=&#x27;http://www.w3.org/2000/svg&#x27;%20version=&#x27;1.1&#x27;%3E%3C/svg%3E" style="max-width:100%;display:block;position:static"/></div><img aria-hidden="true" data-placeholder-image="" style="opacity:1;transition:opacity 500ms linear;background-color:transparent;position:absolute;top:0;left:0;bottom:0;right:0" decoding="async" src="data:image/png;base64," alt=""/><picture><source type="image/webp" data-srcset="/static/c651548c5f84717180f001de7ea47fe2/59d64/henry.webp 100w,/static/c651548c5f84717180f001de7ea47fe2/36c59/henry.webp 220w" sizes="(min-width: 100px) 100px, 100vw"/><img data-gatsby-image-ssr="" data-main-image="" style="opacity:0" sizes="(min-width: 100px) 100px, 100vw" decoding="async" loading="lazy" data-src="/static/c651548c5f84717180f001de7ea47fe2/3d34d/henry.png" data-srcset="/static/c651548c5f84717180f001de7ea47fe2/3d34d/henry.png 100w,/static/c651548c5f84717180f001de7ea47fe2/24674/henry.png 220w" alt="sme"/></picture><noscript><picture><source type="image/webp" srcSet="/static/c651548c5f84717180f001de7ea47fe2/59d64/henry.webp 100w,/static/c651548c5f84717180f001de7ea47fe2/36c59/henry.webp 220w" sizes="(min-width: 100px) 100px, 100vw"/><img data-gatsby-image-ssr="" data-main-image="" style="opacity:0" sizes="(min-width: 100px) 100px, 100vw" decoding="async" loading="lazy" src="/static/c651548c5f84717180f001de7ea47fe2/3d34d/henry.png" srcSet="/static/c651548c5f84717180f001de7ea47fe2/3d34d/henry.png 100w,/static/c651548c5f84717180f001de7ea47fe2/24674/henry.png 220w" alt="sme"/></picture></noscript><script type="module">const t="undefined"!=typeof HTMLImageElement&&"loading"in HTMLImageElement.prototype;if(t){const t=document.querySelectorAll("img[data-main-image]");for(let e of t){e.dataset.src&&(e.setAttribute("src",e.dataset.src),e.removeAttribute("data-src")),e.dataset.srcset&&(e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset"));const t=e.parentNode.querySelectorAll("source[data-srcset]");for(let e of t)e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset");e.complete&&(e.style.opacity=1,e.parentNode.parentNode.querySelector("[data-placeholder-image]").style.opacity=0)}}</script></div><p class="text-center" style="font-family:Poppins,sans-serif;margin-top:18px">“Pezesha has been helpful to me at a time when I needed funds for restocking. My profit margins have increased because I no longer buy from my suppliers on credit, but with cash and attracts discounts all the time. Thanks to Pezesha’s Financial Education modules, I am now equipped with knowledge to run my business”<br/></p><p class="signature" style="font-family:Poppins,sans-serif;font-size:16px">Henry <br/> Fashion &amp; Beauty , Ghana</p></div></div><div class="carousel-item"><div class="col-9 text-center mx-auto testimonial-content"><div data-gatsby-image-wrapper="" class="gatsby-image-wrapper gatsby-image-wrapper-constrained rounded-circle"><div style="max-width:100;display:block"><img alt="" role="presentation" aria-hidden="true" src="data:image/svg+xml;charset=utf-8,%3Csvg%20height=&#x27;100&#x27;%20width=&#x27;100&#x27;%20xmlns=&#x27;http://www.w3.org/2000/svg&#x27;%20version=&#x27;1.1&#x27;%3E%3C/svg%3E" style="max-width:100%;display:block;position:static"/></div><img aria-hidden="true" data-placeholder-image="" style="opacity:1;transition:opacity 500ms linear;background-color:transparent;position:absolute;top:0;left:0;bottom:0;right:0" decoding="async" src="data:image/png;base64," alt=""/><picture><source type="image/webp" data-srcset="/static/a6499b5fce89bd1977e2842600d2c4b4/59d64/jumia.webp 100w,/static/a6499b5fce89bd1977e2842600d2c4b4/5d458/jumia.webp 150w" sizes="(min-width: 100px) 100px, 100vw"/><img data-gatsby-image-ssr="" data-main-image="" style="opacity:0" sizes="(min-width: 100px) 100px, 100vw" decoding="async" loading="lazy" data-src="/static/a6499b5fce89bd1977e2842600d2c4b4/3d34d/jumia.png" data-srcset="/static/a6499b5fce89bd1977e2842600d2c4b4/3d34d/jumia.png 100w,/static/a6499b5fce89bd1977e2842600d2c4b4/be182/jumia.png 150w" alt="sme"/></picture><noscript><picture><source type="image/webp" srcSet="/static/a6499b5fce89bd1977e2842600d2c4b4/59d64/jumia.webp 100w,/static/a6499b5fce89bd1977e2842600d2c4b4/5d458/jumia.webp 150w" sizes="(min-width: 100px) 100px, 100vw"/><img data-gatsby-image-ssr="" data-main-image="" style="opacity:0" sizes="(min-width: 100px) 100px, 100vw" decoding="async" loading="lazy" src="/static/a6499b5fce89bd1977e2842600d2c4b4/3d34d/jumia.png" srcSet="/static/a6499b5fce89bd1977e2842600d2c4b4/3d34d/jumia.png 100w,/static/a6499b5fce89bd1977e2842600d2c4b4/be182/jumia.png 150w" alt="sme"/></picture></noscript><script type="module">const t="undefined"!=typeof HTMLImageElement&&"loading"in HTMLImageElement.prototype;if(t){const t=document.querySelectorAll("img[data-main-image]");for(let e of t){e.dataset.src&&(e.setAttribute("src",e.dataset.src),e.removeAttribute("data-src")),e.dataset.srcset&&(e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset"));const t=e.parentNode.querySelectorAll("source[data-srcset]");for(let e of t)e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset");e.complete&&(e.style.opacity=1,e.parentNode.parentNode.querySelector("[data-placeholder-image]").style.opacity=0)}}</script></div><p class="text-center" style="font-family:Poppins,sans-serif;margin-top:18px">“It has been a pleasure working with Pezesha for the time we have been on this journey together. Their loan application process to our merchants is seamless. Pezesha services also don&#x27;t have any hidden charges and the loans are provided at affordable interest rates for our merchants”<br/></p><p class="signature" style="font-family:Poppins,sans-serif;font-size:16px">Chris <br/> Jumia</p></div></div><div class="carousel-item"><div class="col-9 text-center mx-auto testimonial-content"><div data-gatsby-image-wrapper="" class="gatsby-image-wrapper gatsby-image-wrapper-constrained rounded-circle"><div style="max-width:100;display:block"><img alt="" role="presentation" aria-hidden="true" src="data:image/svg+xml;charset=utf-8,%3Csvg%20height=&#x27;100&#x27;%20width=&#x27;100&#x27;%20xmlns=&#x27;http://www.w3.org/2000/svg&#x27;%20version=&#x27;1.1&#x27;%3E%3C/svg%3E" style="max-width:100%;display:block;position:static"/></div><img aria-hidden="true" data-placeholder-image="" style="opacity:1;transition:opacity 500ms linear;background-color:transparent;position:absolute;top:0;left:0;bottom:0;right:0" decoding="async" src="data:image/png;base64," alt=""/><picture><source type="image/webp" data-srcset="/static/9f9e82fe30db2ff6a6482a5515fb9e76/59d64/marketforce.webp 100w,/static/9f9e82fe30db2ff6a6482a5515fb9e76/5d458/marketforce.webp 150w" sizes="(min-width: 100px) 100px, 100vw"/><img data-gatsby-image-ssr="" data-main-image="" style="opacity:0" sizes="(min-width: 100px) 100px, 100vw" decoding="async" loading="lazy" data-src="/static/9f9e82fe30db2ff6a6482a5515fb9e76/3d34d/marketforce.png" data-srcset="/static/9f9e82fe30db2ff6a6482a5515fb9e76/3d34d/marketforce.png 100w,/static/9f9e82fe30db2ff6a6482a5515fb9e76/be182/marketforce.png 150w" alt="sme"/></picture><noscript><picture><source type="image/webp" srcSet="/static/9f9e82fe30db2ff6a6482a5515fb9e76/59d64/marketforce.webp 100w,/static/9f9e82fe30db2ff6a6482a5515fb9e76/5d458/marketforce.webp 150w" sizes="(min-width: 100px) 100px, 100vw"/><img data-gatsby-image-ssr="" data-main-image="" style="opacity:0" sizes="(min-width: 100px) 100px, 100vw" decoding="async" loading="lazy" src="/static/9f9e82fe30db2ff6a6482a5515fb9e76/3d34d/marketforce.png" srcSet="/static/9f9e82fe30db2ff6a6482a5515fb9e76/3d34d/marketforce.png 100w,/static/9f9e82fe30db2ff6a6482a5515fb9e76/be182/marketforce.png 150w" alt="sme"/></picture></noscript><script type="module">const t="undefined"!=typeof HTMLImageElement&&"loading"in HTMLImageElement.prototype;if(t){const t=document.querySelectorAll("img[data-main-image]");for(let e of t){e.dataset.src&&(e.setAttribute("src",e.dataset.src),e.removeAttribute("data-src")),e.dataset.srcset&&(e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset"));const t=e.parentNode.querySelectorAll("source[data-srcset]");for(let e of t)e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset");e.complete&&(e.style.opacity=1,e.parentNode.parentNode.querySelector("[data-placeholder-image]").style.opacity=0)}}</script></div><p class="text-center" style="font-family:Poppins,sans-serif;margin-top:18px">“Pezesha has been a great partner and has enabled us to develop new products and to also expand our operations to Uganda”<br/></p><p class="signature" style="font-family:Poppins,sans-serif;font-size:16px">Tyler <br/> Marketforce</p></div></div></div><div><a class="carousel-control-prev" href="#carousel-t" role="button" data-bs-slide="prev"><span class="carousel-control-prev-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16" class="bi bi-arrow-left" style="color:rgb(0,0,0);font-size:40px"><path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"></path></svg></span><span class="visually-hidden" style="background:#000000">Previous</span></a><a class="carousel-control-next" href="#carousel-t" ro