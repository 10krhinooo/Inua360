# ── Email service (required for the waitlist form) ────────────────────────────
# URL where the email-service is running.
# Local dev:  http://localhost:3001
# Production: the URL of your deployed email-service (Railway, Render, Fly.io, etc.)
VITE_EMAIL_SERVICE_URL=https://inua360-five.vercel.app
VITE_EMAIL_SERVICE_URL=http://localhost:3001

# Bearer token used to authenticate requests to the email-service.
# Must be the same value as AUTH_TOKEN in email-service/.env
# Generate with: openssl rand -hex 32
VITE_EMAIL_SERVICE_TOKEN=

# ── Backend API ───────────────────────────────────────────────────────────────
# URL of the Django REST API. Defaults to http://localhost:8000/api/v1 if unset.
# VITE_API_BASE_URL=http://localhost:8000/api/v1


