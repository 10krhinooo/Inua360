# ─── Vercel (Dashboard → Project → Settings → Environment Variables) ──────────
#
# Required — the email address where waitlist signups are delivered.
# Set this EXACTLY as shown (no VITE_ prefix) in Vercel's environment variables.
#
# WAITLIST_NOTIFY_EMAIL=hello.inua360@gmail.com
#
# FormSubmit activation (one-time):
#   The very first submission to a new email triggers a confirmation email from
#   FormSubmit. Open hello.inua360@gmail.com → check spam → click the link.
#   Until you click it, FormSubmit will NOT deliver any signup emails.

# ─── Local development (`npm run dev`) ────────────────────────────────────────
# Set VITE_WAITLIST_NOTIFY_EMAIL so the dev build can send directly via FormSubmit.
# Use the same activated email address.
VITE_WAITLIST_NOTIFY_EMAIL=

# Optional
# VITE_API_BASE_URL=http://localhost:8000/api/v1
# VITE_GOOGLE_CLIENT_ID=
