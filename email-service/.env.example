# ── Auth ──────────────────────────────────────────────────────────────────────
# Shared secret between the frontend and this service.
# The frontend sends this in every request as: Authorization: Bearer <AUTH_TOKEN>
# Generate with: openssl rand -hex 32
AUTH_TOKEN=

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Gmail address that sends the confirmation emails.
SMTP_USER=

# Gmail App Password — NOT your regular Gmail password.
# How to get one: Google Account → Security → 2-Step Verification → App passwords
# Create an app called "Inua360 Email Service" and paste the 16-char password here.
SMTP_PASS=

# Name shown in the email From field (e.g. "Inua360").
SMTP_FROM_NAME=Inua360

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated list of frontend origins allowed to call this service.
# Include both local dev and the deployed Vercel URL.
CORS_ORIGINS=http://localhost:5173,https://inua360.vercel.app
